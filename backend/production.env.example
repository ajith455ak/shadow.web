# ---------- DATABASE CONFIGURATION ----------
# Connection URL to your production MongoDB cluster (e.g., MongoDB Atlas)
MONGO_URL=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
DB_NAME=shadow_nexus_prod

# ---------- SECURITY CONFIGURATION ----------
# A strong, unique secret key used to sign session JSON Web Tokens (JWT)
JWT_SECRET=super-secret-jwt-signing-key-change-this-in-production

# ---------- LLM INTEGRATION ----------
# Optional API Key for the LLM provider (e.g. Anthropic/Claude integration)
EMERGENT_LLM_KEY=your-emergent-llm-api-key

# ---------- SMTP MAIL CONFIGURATION ----------
# Configure these variables to enable real asynchronous email verification dispatch.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-smtp-api-password-or-token
SMTP_FROM_EMAIL=noreply@shadow-nexus.io
